# Example environment for the FastAPI + React + LLM project
# Copy the values you need into your real environment or local .env files.

# Backend
PORT=8000
LOG_LEVEL=info
API_KEY=

# LLM mode: OpenAI-compatible provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
OPENAI_MAX_TOKENS=512
OPENAI_TEMPERATURE=0.3
LLM_SYSTEM_PROMPT=Tu es un assistant CV professionnel. Aide l'utilisateur a rediger, ameliorer et structurer son CV.

# LLM mode: local command
# Examples:
# LLM_CMD=python backend\app\llm_wrapper.py {prompt}
# LLM_CMD=C:\path\to\local-llm.exe {prompt}
LLM_CMD=

# Frontend
# The frontend normalizes this value to end with /api automatically.
REACT_APP_API_URL=http://localhost:8000
REACT_APP_SERVER_API_KEY=
REACT_APP_ENV=development
DISABLE_ESLINT_PLUGIN=true
